{
  "name": "retry-status-bar",
  "displayName": "Retry Status Bar",
  "description": "Show retry count and recent retry errors in the VS Code status bar.",
  "version": "0.2.17",
  "publisher": "wister-xue",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:retryStatusBar.showLog",
    "onCommand:retryStatusBar.refresh",
    "onCommand:retryStatusBar.dumpAntigravityContext"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "retryStatusBar.showLog",
        "title": "Retry Status Bar: Show Log"
      },
      {
        "command": "retryStatusBar.refresh",
        "title": "Retry Status Bar: Refresh"
      },
      {
        "command": "retryStatusBar.dumpAntigravityContext",
        "title": "Retry Status Bar: Dump Antigravity Context"
      }
    ],
    "configuration": {
      "title": "Retry Status Bar",
      "properties": {
        "retryStatusBar.statusUrl": {
          "type": "string",
          "default": "http://127.0.0.1:38475/__status",
          "description": "HTTP endpoint that returns the retry status JSON."
        },
        "retryStatusBar.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 500,
          "description": "Polling interval in milliseconds."
        },
        "retryStatusBar.showWhenIdle": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar item even when there is no active retry."
        },
        "retryStatusBar.idleText": {
          "type": "string",
          "default": "0",
          "description": "Text to show when showWhenIdle is enabled and no retry is active."
        },
        "retryStatusBar.maxTooltipEvents": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "How many recent retry events to show in the tooltip."
        }
      }
    }
  }
}
